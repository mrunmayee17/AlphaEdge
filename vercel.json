{
  "framework": "vite",
  "installCommand": "npm install --prefix frontend",
  "buildCommand": "npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "devCommand": "npm run dev --prefix frontend -- --host 0.0.0.0 --port 3000",
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "http://ec2-3-142-251-252.us-east-2.compute.amazonaws.com/api/v1/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
